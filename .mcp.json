{
  "name": "notification-ai-mcp",
  "description": "Notification Ai tools for AI agents. Capabilities: send webhook, send desktop notification, schedule notification. Built by MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "send_webhook",
      "description": "MEOK AI Labs tool.",
      "parameters": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "payload": {
            "type": "string"
          }
        },
        "required": [
          "url",
          "payload"
        ]
      }
    },
    {
      "name": "send_desktop_notification",
      "description": "MEOK AI Labs tool.",
      "parameters": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "message"
        ]
      }
    },
    {
